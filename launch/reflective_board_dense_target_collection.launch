<launch>
  <!-- Collect one dense accumulated target-board cloud after traditional detection confirms. -->

  <arg name="start_driver" default="true"/>
  <arg name="input_topic" default="/livox/lidar"/>
  <arg name="dataset_root" default="/home/sunrise/catkin_ws/dataset"/>
  <arg name="scene_id" default="dense_target"/>
  <arg name="run_id" default=""/>
  <arg name="template_path"
       default="$(find livox_reflective_marker)/config/target_board_template.yaml"/>
  <arg name="rviz" default="true"/>
  <arg name="driver_launch_prefix" default=""/>
  <arg name="driver_output" default="log"/>

  <include file="$(find livox_reflective_marker)/launch/reflective_board_dataset_collection.launch">
    <arg name="start_driver" value="$(arg start_driver)"/>
    <arg name="input_topic" value="$(arg input_topic)"/>
    <arg name="dataset_root" value="$(arg dataset_root)"/>
    <arg name="collection_mode" value="dense_target"/>
    <arg name="scene_id" value="$(arg scene_id)"/>
    <arg name="run_id" value="$(arg run_id)"/>
    <arg name="template_path" value="$(arg template_path)"/>
    <arg name="rviz" value="$(arg rviz)"/>
    <arg name="driver_launch_prefix" value="$(arg driver_launch_prefix)"/>
    <arg name="driver_output" value="$(arg driver_output)"/>
  </include>
</launch>
