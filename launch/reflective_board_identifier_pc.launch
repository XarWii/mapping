<launch>
  <!-- PC-side Task 1 launch: start Livox driver and run identification with visualization disabled. -->

  <arg name="start_driver" default="true"/>
  <arg name="input_topic" default="/livox/lidar"/>
  <arg name="driver_launch_prefix" default=""/>
  <arg name="driver_output" default="log"/>
  <arg name="template_path"
       default="$(find livox_reflective_marker)/config/target_board_template.yaml"/>
  <arg name="result_output_dir"
       default="$(find livox_reflective_marker)/tmp/reflective_board_results"/>

  <group if="$(arg start_driver)">
    <param name="xfer_format" value="1"/>
    <param name="multi_topic" value="0"/>
    <param name="data_src" value="0"/>
    <param name="publish_freq" type="double" value="10.0"/>
    <param name="output_data_type" value="0"/>
    <param name="user_config_path" type="string"
           value="$(find livox_ros_driver2)/config/MID360s_config.json"/>
    <param name="frame_id" type="string" value="livox_frame"/>
    <param name="enable_lidar_bag" type="bool" value="true"/>
    <param name="enable_imu_bag" type="bool" value="true"/>

    <node name="livox_lidar_publisher2" pkg="livox_ros_driver2"
          type="livox_ros_driver2_node" required="true"
          output="$(arg driver_output)" launch-prefix="$(arg driver_launch_prefix)"/>
  </group>

  <node pkg="livox_reflective_marker"
        type="reflective_board_identifier_node"
        name="reflective_board_identifier_node"
        output="screen"
        required="true">
    <rosparam command="load"
              file="$(find livox_reflective_marker)/config/params.yaml"/>
    <param name="input_topic" value="$(arg input_topic)"/>
    <param name="task1/template_path" value="$(arg template_path)"/>
    <param name="task1/result_output_dir" value="$(arg result_output_dir)"/>

    <!-- Disable visualization/debug point clouds for remote PC runs. -->
    <param name="task1/publish_raw_cloud" value="false"/>
    <param name="task1/publish_candidate_cloud" value="false"/>
    <param name="task1/publish_high_reflective_cloud" value="false"/>
    <param name="task1/publish_template_match_cloud" value="false"/>
    <param name="task1/publish_markers" value="false"/>
  </node>
</launch>
